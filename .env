# TraderNet API
TRADERNET_PUBLIC_KEY=your_public_key
TRADERNET_PRIVATE_KEY=your_private_key
TRADERNET_TICKER=TECHSMART

# MAX Bot (вместо Telegram)
MAX_BOT_TOKEN=your_max_bot_token
MAX_CHAT_ID=123456789  # ID пользователя в MAX

# VseGPT AI
VSEGPT_API_KEY=your_api_key
VSEGPT_API_URL=https://api.vsegpt.ru/v1
VSEGPT_MODEL=anthropic/claude-3-haiku
VSEGPT_MAX_TOKENS=300
VSEGPT_TEMPERATURE=0.2

# Настройки детектора
SETUP_SCORE_REQUIRED=40
AI_CONFIDENCE_REQUIRED=80
AI_COOLDOWN_SECONDS=120
MIN_BIAS_FOR_AI=3
MIN_DELTA_FOR_AI=5000

# Пороги для TECHSMART
MIN_PRINT_VOLUME=500
MIN_DELTA_VOLUME=200
DELTA_THRESHOLD=7000
TAPE_SPEED_THRESHOLD=15
ABSORPTION_THRESHOLD=2000
BIG_WALL_SIZE=5000
SPOOF_SIZE_THRESHOLD=3000
ICEBERG_MIN_VOLUME=500
PRICE_RESPONSE_THRESHOLD=1000